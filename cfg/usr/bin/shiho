#!/data/data/com.termux/files/usr/bin/env bash
# SPDX-License-Identifier: 0BSD
# Connect to Shizuku (https://github.com/RikkaApps/Shizuku)
set -e

usage() {
  echo "usage: ${0##*/} [-h]"
  echo
  echo 'connect to shizuku (https://github.com/rikkaapps/shizuku)'
  echo
  echo 'options:'
  echo '  -h  show this help message and exit'
  exit "${1}"
}

main() {
  [[ "${@}" == '-h' ]] && usage 0

  local dex="${HOME}/shizuku/rish_shizuku.dex"
  [[ -w "${dex}" ]] && chmod 400 "${dex}"

  RISH_APPLICATION_ID='com.termux' /system/bin/app_process \
    -Djava.class.path="${dex}" /system/bin --nice-name=rish \
    rikka.shizuku.shell.ShizukuShellLoader "${@}"
}

main "${@}"
