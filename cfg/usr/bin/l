#!/data/data/com.termux/files/usr/bin/env bash
# SPDX-License-Identifier: 0BSD
# ls alias
set -e

usage() {
  echo "usage: ${0##*/} [-h] PATH"
  echo
  echo 'ls alias'
  echo
  echo 'options:'
  echo '  -h  show this help message and exit'
  exit "${1}"
}

main() {
  [[ "${@}" == '-h' ]] && usage 0

  LS_COLORS='ow=1;34:tw=1;34' ls -Ggaph --time-style=+ \
    --color=always -- "${@}" | column
}

main "${@}"
